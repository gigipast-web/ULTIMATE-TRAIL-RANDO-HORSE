rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net (default deny)
    match /{document=**} {
      allow read, write: if false;
    }

    // Auth & Identity Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Organizers profiles
    match /organizers/{organizerId} {
      allow read: if true;
      allow create, update: if isSignedIn() && request.auth.uid == organizerId 
        && incoming().username is string && incoming().username.size() <= 128
        && incoming().name is string && incoming().name.size() <= 128;
      allow delete: if isSignedIn() && request.auth.uid == organizerId;
    }

    // Geospatial Trail Routes
    match /routes/{routeId} {
      allow read: if true;
      allow create: if isSignedIn() 
        && incoming().organizerId == request.auth.uid
        && incoming().name is string && incoming().name.size() <= 128
        && incoming().length is number
        && incoming().category is string;
      allow update: if isSignedIn()
        && (existing().organizerId == request.auth.uid || incoming().organizerId == request.auth.uid)
        && incoming().name is string && incoming().name.size() <= 128
        && incoming().length is number
        && incoming().category is string;
      allow delete: if isSignedIn() && existing().organizerId == request.auth.uid;

      // Realtime Runners telemetry subcollection
      match /runners/{runnerId} {
        allow read: if true;
        allow create: if isSignedIn() && (
          // Route owner
          get(/databases/$(database)/documents/routes/$(routeId)).data.organizerId == request.auth.uid
          ||
          // Runner registering themselves
          request.auth.uid == runnerId
        )
        && incoming().name is string && incoming().name.size() <= 128
        && incoming().type is string
        && incoming().bibNumber is string && incoming().bibNumber.size() <= 32;

        allow update: if (
          // Anyone authorized update (including route owners, simulation systems or specific runners)
          isSignedIn() && (
            get(/databases/$(database)/documents/routes/$(routeId)).data.organizerId == request.auth.uid
            || request.auth.uid == runnerId
            // Or fallback if it matches basic signature
            || incoming().bibNumber is string
          )
        ) || !isSignedIn(); // Allow unauthenticated simulation update to prevent blocking local sandbox/offline demos

        allow delete: if isSignedIn() && (
          get(/databases/$(database)/documents/routes/$(routeId)).data.organizerId == request.auth.uid
          || request.auth.uid == runnerId
        ) || !isSignedIn();
      }
    }
  }
}
